generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(uuid()) @map("id")
  email             String           @unique @map("email")
  passwordHash      String           @map("password_hash")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  fullName          String           @map("full_name")
  expectedIncome    Decimal?         @map("expected_income")
  hasSeenOnboarding Boolean          @default(false)
  weightEntries     WeightEntry[]
  budgets           Budget[]
  calendarEvents    CalendarEvent[]
  chatbotMessages   ChatbotMessage[]
  diets             Diet[]
  expenses          Expense[]
  fitnessInfo       FitnessInfo?
  incomeEntries     IncomeEntry[]
  notes             Note[]

  @@map("users")
}

model Budget {
  id          String    @id @default(uuid()) @map("id")
  name        String    @map("name")
  limitAmount Decimal   @map("limit_amount")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  expenses    Expense[]

  @@map("budgets")
}

model Expense {
  id          String   @id @default(uuid()) @map("id")
  amount      Decimal  @map("amount")
  category    String   @map("category")
  description String   @map("description")
  expenseDate DateTime @map("expense_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  userId      String   @map("user_id")
  budgetId    String   @map("budget_id")
  budget      Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@map("expenses")
}

model IncomeEntry {
  id         String   @id @default(uuid()) @map("id")
  amount     Decimal  @map("amount")
  note       String?  @map("note")
  incomeDate DateTime @default(now()) @map("income_date")
  createdAt  DateTime @default(now()) @map("created_at")
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("income_entries")
}

model Note {
  id        String   @id @default(uuid()) @map("id")
  title     String   @map("title")
  content   String   @map("content")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  @@map("notes")
}

model CalendarEvent {
  id          String    @id @default(uuid()) @map("id")
  title       String    @map("title")
  description String?   @map("description")
  startTime   DateTime  @map("start_time")
  endTime     DateTime? @map("end_time")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])

  @@map("calendar_events")
}

model FitnessInfo {
  id            String   @id @default(uuid()) @map("id")
  currentWeight Decimal? @map("current_weight")
  goalWeight    Decimal? @map("goal_weight")
  calorieGoal   Int?     @map("calorie_goal")
  proteinGoal   Int?     @map("protein_goal")
  carbsGoal     Int?     @map("carbs_goal")
  fatGoal       Int?     @map("fat_goal")
  updatedAt     DateTime @updatedAt @map("updated_at")
  userId        String   @unique @map("user_id")
  age           Int?     @map("age")
  heightFt      Decimal? @map("height_ft")
  user          User     @relation(fields: [userId], references: [id])

  @@map("fitness_info")
}

model WeightEntry {
  id        String   @id @default(uuid())
  weight    Decimal
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Diet {
  id              String            @id @default(uuid()) @map("id")
  name            String            @map("name")
  description     String?           @map("description")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  userId          String            @map("user_id")
  isActive        Boolean           @default(false) @map("is_active")
  dietItems       DietItem[]
  presetMealItems PresetMealItems[]
  user            User              @relation(fields: [userId], references: [id])

  @@map("diets")
}

model DietItem {
  id        String   @id @default(uuid()) @map("id")
  name      String   @map("name")
  meal      MealType
  calories  Int
  protein   Float?
  carbs     Float?
  fat       Float?
  sugar     Float?
  quantity  Float?
  unit      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  dietId    String   @map("diet_id")
  loggedAt  DateTime @default(now()) @map("logged_at")
  diet      Diet     @relation(fields: [dietId], references: [id], onDelete: Cascade)
}

model PresetMealItems {
  id       String   @id @default(uuid()) @map("id")
  name     String   @map("name")
  meal     MealType
  calories Int
  protein  Float?
  carbs    Float?
  fat      Float?
  sugar    Float?
  quantity Float?
  unit     String?
  dietId   String   @map("diet_id")
  diet     Diet     @relation(fields: [dietId], references: [id], onDelete: Cascade)
}

model FoodCache {
  id                  String   @id @default(uuid()) @map("id")
  fdcId               Int      @unique @map("fdcId")
  name                String   @map("name")
  brand               String?  @map("brand")
  dataType            String?  @map("dataType")
  servingSize         Float?   @map("serving_size")
  servingSizeOriginal Float?   @map("serving_size_original")
  servingUnit         String?  @map("serving_unit")
  servingUnitOriginal String?  @map("serving_unit_original")
  calories            Float?   @map("calories")
  protein             Float?   @map("protein")
  carbs               Float?   @map("carbs")
  fat                 Float?   @map("fat")
  sugar               Float?   @map("sugar")
  createdAt           DateTime @default(now()) @map("createdAt")

  @@map("food_cache")
}

model ChatbotMessage {
  id        String   @id @default(uuid()) @map("id")
  sender    Sender   @map("sender")
  message   String   @map("message")
  createdAt DateTime @default(now()) @map("created_at")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  @@map("chatbot_messages")
}

enum Sender {
  user
  bot
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACKS
}
